# Zkopíruj na `.env.local` a doplň hodnoty (lokálně). Na Netlify nastav
# tyto proměnné v Site settings → Environment variables.

# Basic auth přes celou stránku. Když obě proměnné nastavíš, web se schová za
# přihlašovací dialog. Když je necháš prázdné, web je bez hesla (vhodné lokálně).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
